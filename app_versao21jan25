# ============= PARCELS FUNCTIONS =============
def save_parcel(name, vegetation, risk, geometry_json):
    # Log para debug no terminal
    print(f"Tentativa de guardar: {name}, Geometria: {geometry_json[:50]}...")

    if not geometry_json or len(geometry_json.strip()) < 10:
        return "Erro: O mapa não enviou a geometria. Tente desenhar novamente.", get_parcels_list(), ""
    
    try:
        geometry_dict = json.loads(geometry_json)
        geom = GEOSGeometry(json.dumps(geometry_dict), srid=4326)
        
        FireParcel.objects.create(
            name=name,
            vegetation_type=vegetation,
            risk_level=risk,
            geometry=geom
        )
        return f"✓ Parcela '{name}' guardada!", get_parcels_list(), reload_map_parcels()
    except Exception as e:
        return f"Erro técnico: {str(e)}", get_parcels_list(), ""
    
def get_parcels_list():
    parcels = FireParcel.objects.all().values('id', 'name', 'vegetation_type', 'risk_level')
    return [[p['id'], p['name'], p['vegetation_type'], p['risk_level']] for p in parcels]

def get_parcels_geojson():
    parcels = FireParcel.objects.all()
    features = []
    for parcel in parcels:
        try:
            geometry = json.loads(parcel.geometry.geojson)
            features.append({
                "type": "Feature",
                "properties": {
                    "id": parcel.id,
                    "name": parcel.name,
                    "risk_level": parcel.risk_level, # ESSENCIAL PARA A COR
                    "vegetation_type": parcel.vegetation_type
                },
                "geometry": geometry
            })
        except: continue
    return json.dumps({"type": "FeatureCollection", "features": features})

def load_parcels_to_map():
    geojson = get_parcels_geojson()
    return f"""
