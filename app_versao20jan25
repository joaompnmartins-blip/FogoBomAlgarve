# ============= PARCELS FUNCTIONS =============
def save_parcel(name, vegetation, risk, geometry_json):
    if not geometry_json or geometry_json.strip() == "":
        return "No geometry provided - please draw a polygon on the map first", get_parcels_list()
    
    try:
        geometry_dict = json.loads(geometry_json)
        geom = GEOSGeometry(json.dumps(geometry_dict), srid=4326)
        
        FireParcel.objects.create(
            name=name,
            vegetation_type=vegetation,
            risk_level=risk,
            geometry=geom
        )
        return f"✓ Parcel '{name}' saved successfully!", get_parcels_list() , reload_map_parcels()
    except json.JSONDecodeError as e:
        return f"Error: Invalid geometry JSON - {str(e)}", get_parcels_list()
    except Exception as e:
        return f"Error saving parcel: {str(e)}", get_parcels_list()

def get_parcels_list():
    parcels = FireParcel.objects.all().values('id', 'name', 'vegetation_type', 'risk_level')
    return [[p['id'], p['name'], p['vegetation_type'], p['risk_level']] for p in parcels]

def get_parcels_geojson():
    """Get all parcels as GeoJSON for map display"""
    parcels = FireParcel.objects.all()
    print(f"\n=== get_parcels_geojson called ===")
    print(f"Found {parcels.count()} parcels in database")
    
    features = []
    
    for parcel in parcels:
        try:
            geometry = json.loads(parcel.geometry.geojson)
            feature = {
                "type": "Feature",
                "properties": {
                    "id": parcel.id,
                    "name": parcel.name,
                    "vegetation_type": parcel.vegetation_type,
                    "risk_level": parcel.risk_level
                },
                "geometry": geometry
            }
            features.append(feature)
            print(f"  ✓ Added parcel: {parcel.name} (ID: {parcel.id})")
        except Exception as e:
            print(f"  ✗ Error adding parcel {parcel.name}: {e}")
    
    result = {
        "type": "FeatureCollection",
        "features": features
    }
    
    json_result = json.dumps(result)
    print(f"Final GeoJSON length: {len(json_result)} chars")
    print(f"GeoJSON preview: {json_result[:500]}...")
    print("=" * 50)
    
    return json_result

def load_parcels_to_map():
    """Retorna JavaScript para carregar as parcelas no mapa ao iniciar"""
    geojson = get_parcels_geojson()
    return f"""
    <script>
    (function() {{
        const sendToIframe = () => {{
            const iframe = document.getElementById('map-iframe');
            if (iframe && iframe.contentWindow) {{
                console.log('Enviando parcelas para o mapa...');
                iframe.contentWindow.postMessage({{
                    type: 'load_parcels',
                    geojson: {geojson}  // Injetado como objeto literal JS
                }}, '*');
            }}
        }};
        // Tenta enviar em diferentes intervalos para garantir que o Leaflet já iniciou
        setTimeout(sendToIframe, 500);
        setTimeout(sendToIframe, 1500);
        setTimeout(sendToIframe, 3000);
    }})();
    </script>
    """

def reload_map_parcels():
    """Envia os dados GeoJSON atuais diretamente para o iframe"""
    geojson = get_parcels_geojson()
    return f"""
    <script>
    (function() {{
        const iframe = document.getElementById('map-iframe');
        if (iframe && iframe.contentWindow) {{
            iframe.contentWindow.postMessage({{
                type: 'load_parcels',
                geojson: {geojson}
            }}, '*');
            console.log("Dados enviados via postMessage");
        }}
    }})();
    </script>
    """
