# ============= OPERATIVES FUNCTIONS =============
def create_operative(name, email, phone, certification):
    try:
        Operative.objects.create(
            name=name,
            email=email,
            phone=phone,
            certification_level=certification
        )
        return f"✓ Operative '{name}' created successfully!", get_operatives_list()
    except Exception as e:
        return f"Error creating operative: {str(e)}", get_operatives_list()

def update_operative(operative_id, name, email, phone, certification):
    try:
        operative = Operative.objects.get(id=operative_id)
        operative.name = name
        operative.email = email
        operative.phone = phone
        operative.certification_level = certification
        operative.save()
        return f"✓ Operative updated successfully!", get_operatives_list()
    except Operative.DoesNotExist:
        return "Error: Operative not found", get_operatives_list()
    except Exception as e:
        return f"Error updating operative: {str(e)}", get_operatives_list()

def delete_operative(operative_id):
    try:
        operative = Operative.objects.get(id=operative_id)
        name = operative.name
        operative.delete()
        return f"✓ Operative '{name}' deleted successfully!", get_operatives_list()
    except Operative.DoesNotExist:
        return "Error: Operative not found", get_operatives_list()
    except Exception as e:
        return f"Error deleting operative: {str(e)}", get_operatives_list()

def get_operatives_list():
    operatives = Operative.objects.all().values('id', 'name', 'email', 'phone', 'certification_level')
    return [[op['id'], op['name'], op['email'], op['phone'], op['certification_level']] for op in operatives]

def load_operative_details(evt: gr.SelectData):
    operative_id = evt.value[0] if evt.value else None
    if not operative_id:
        return None, "", "", "", ""
    
    try:
        operative = Operative.objects.get(id=operative_id)
        return operative.id, operative.name, operative.email, operative.phone, operative.certification_level
    except:
        return None, "", "", "", ""

# ============= FIRE ACTIONS FUNCTIONS =============
def create_fire_action(name, scheduled_date, parcel_ids, operative_ids, notes, photos):
    try:
        action = FireAction.objects.create(
            name=name,
            scheduled_date=scheduled_date,
            notes=notes
        )
        
        if parcel_ids:
            parcels = FireParcel.objects.filter(id__in=parcel_ids)
            action.parcels.set(parcels)
        
        if operative_ids:
            operatives = Operative.objects.filter(id__in=operative_ids)
            action.operatives.set(operatives)
        
        # Handle photo uploads (simplified - in production you'd save to storage)
        if photos:
            action.notes += f"\n\n[{len(photos)} photo(s) uploaded]"
            action.save()
        
        return f"✓ Fire Action '{name}' created successfully!", get_fire_actions_list()
    except Exception as e:
        return f"Error creating fire action: {str(e)}", get_fire_actions_list()

def get_fire_actions_list():
    actions = FireAction.objects.all()
    result = []
    for action in actions:
        parcel_names = ", ".join([p.name for p in action.parcels.all()])
        operative_names = ", ".join([o.name for o in action.operatives.all()])
        result.append([
            action.id,
            action.name,
            str(action.scheduled_date),
            action.status,
            parcel_names,
            operative_names
        ])
    return result

