def update_operative(operative_id, name, email, phone, certification):
    
    if not operative_id:
        return "❌ Selecione um operacional primeiro!", "*Selecione um operacional na tabela para ver os detalhes*"
    
    if not name or not email:
        return "❌ Nome e email são obrigatórios!", get_operative_details(operative_id)
    
    try:
        operative = Operative.objects.get(id=operative_id)
        operative.name = name
        operative.email = email
        operative.phone = phone
        operative.certification_level = certification
        operative.save()
        
        actions = operative.fire_actions.all()
        actions_summary = f"### 📋 Detalhes de {operative.name}\n\n"
        actions_summary += f"**ID:** {operative.id}\n\n"
        actions_summary += f"✅ **Dados atualizados com sucesso!**\n\n"
        actions_summary += f"**Ações Associadas:** {actions.count()}\n\n"
        
        if actions.exists():
            actions_summary += "**Histórico de Ações:**\n"
            for action in actions[:5]:
                actions_summary += f"- {action.name} ({action.scheduled_date}) - {action.status}\n"
            if actions.count() > 5:
                actions_summary += f"\n... e mais {actions.count() - 5} ação(ões)"
        else:
            actions_summary += "*Nenhuma ação associada*"
        
        return f"✓ Operacional '{name}' atualizado com sucesso!", actions_summary
    except Operative.DoesNotExist:
        return "❌ Operacional não encontrado", "*Erro ao atualizar*"
    except Exception as e:
        return f"Erro ao atualizar: {str(e)}", "*Erro ao atualizar*"

def delete_operative(operative_id):
    
    if not operative_id:
        return "❌ Selecione um operacional primeiro!", get_filtered_operatives("", "")
    
    try:
        operative = Operative.objects.get(id=operative_id)
        name = operative.name
        
        actions_count = operative.fire_actions.count()
        if actions_count > 0:
            return f"⚠️ Não é possível eliminar '{name}' - tem {actions_count} ação(ões) associada(s)!", get_filtered_operatives("", "")
        
        operative.delete()
        return f"✓ Operacional '{name}' eliminado com sucesso!", get_filtered_operatives("", "")
    except Operative.DoesNotExist:
        return "❌ Operacional não encontrado", get_filtered_operatives("", "")
    except Exception as e:
        return f"Erro ao eliminar: {str(e)}", get_filtered_operatives("", "")

def get_operatives_summary():
    operatives = Operative.objects.all()
    total = operatives.count()
    by_cert = operatives.values('certification_level').annotate(count=Count('certification_level'))
    
    summary = f"**Total de Operacionais:** {total}\n\n"
    summary += "**Distribuição por Certificação:**\n"
    for item in by_cert:
        summary += f"- {item['certification_level']}: {item['count']}\n"
    
    return summary

def get_filtered_operatives(search_term, certification_filter):
    operatives = Operative.objects.all()
    
    if search_term and search_term.strip():
        operatives = operatives.filter(
            Q(name__icontains=search_term) | 
            Q(email__icontains=search_term) |
            Q(phone__icontains=search_term)
        )
    
    if certification_filter and certification_filter != "Todos":
        operatives = operatives.filter(certification_level=certification_filter)
    
    result = []
    for op in operatives:
        actions_count = op.fire_actions.count()
        result.append([
            op.id,
            op.name,
            op.email,
            op.phone,
            op.certification_level,
            actions_count
        ])
    
    return result

